# --- 开发工具配置 ---
^\.Rprofile$
^.*\.Rproj$
^\.Rproj\.user$
^\.vscode$
^\.github$
^_pkgdown\.yml$
^pkgdown$
^docs$

# --- R 包构建产物 ---
^doc$
^Meta$
^visPedigree_.*\.tar\.gz$
^tar_contents\.txt$

# --- 临时脚本与测试 (CRAN 不接受非 tests/ 目录下的测试脚本) ---
^check_.*\.R$
^test_.*\.R$
^demo_.*\.R$
^find_.*\.R$
^explain_.*\.R$
^verify_.*\.R$

# --- 临时文档与数据 ---
^todo\.md$
^todo$
^cran-comments\.md$
^DEVELOPMENT\.md$
^CODE_REVIEW_FIXES\.md$
^CRAN-SUBMISSION$
^manuscript\.md$
^MACOS_OPENMP_FIX\.md$
^inst/extdata/complex_100gen_ped\.rda$
^papers$

# --- 开发过程产生的临时文件 ---
^Rplots\.pdf$
^.*\.png$
^sandbox$
^Positron\.md$
